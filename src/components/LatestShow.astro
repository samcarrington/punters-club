---
import { Icon } from "astro-icon/components";
import type { Show } from "../lib/mixcloud";
import MixcloudWidget from "./MixcloudWidget.astro";

const { show } = Astro.props as { show: Show };
---

<article class="feature-card">
  <div class="feature-card-body">
    <div class="feature-card-info">
      <h3>{show.title}</h3>
      <p>{show.description || 'Latest Mixcloud broadcast.'}</p>
    </div>
    <MixcloudWidget show={show} />
    <a href={show.url} target="_blank" rel="noreferrer" class="link-external">Open on Mixcloud<span class="sr-only"> (opens in new tab)</span> <Icon height=".8em" name="gridicons:external" /></a>
  </div>
</article>
