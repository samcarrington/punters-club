---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import rawResult from "../data/next-show.generated.json";
import type { NextShowResult } from "../lib/next-show";

const result = rawResult as NextShowResult;

const upcoming = result.status === "upcoming" ? result.show : undefined;
const cueLabel =
  upcoming?.matchedBy === "guest" ? "Guest appearance" : "Punters Club show";

function formatWhen(startsAtUtc: string, timeZone: string) {
  const date = new Date(startsAtUtc);
  const formatter = new Intl.DateTimeFormat("en-GB", {
    weekday: "short",
    day: "numeric",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
    timeZone,
  });
  return formatter.format(date);
}
---
{result.status === "upcoming" ? (
  <article class="next-show-insert">
    <header class="next-show-header">
      <h2 class="next-show-label">Next show</h2>
      <span class="next-show-match-badge">{cueLabel}</span>
    </header>
    <div class="next-show-body">
      {result.show.posterUrl && (
        <Image
         src={result.show.posterUrl} 
         alt="The Punters' Club Next Show Poster" 
         height="512"
         width="512"
         class="next-show-poster" 
         loading="lazy" />
      )}
      
      <div class="next-show-details">
        <time class="next-show-when" datetime={result.show.startsAtUtc}>
          {formatWhen(result.show.startsAtUtc, result.show.timezone)}
        </time>
        <h3 class="next-show-title">{result.show.title}</h3>
        {result.show.description && <p class="next-show-desc">{result.show.description}</p>}
        <a href={result.show.url} class="next-show-link link-external" target="_blank" rel="noreferrer">
          View on Radio Waters
          <span class="sr-only"> (opens in new tab)</span>
          <Icon height=".8em" name="gridicons:external" />
        </a>
      </div>
    </div>
  </article>
) : (
  <div class="next-show-insert is-empty">
    <h2 class="next-show-label">Next show</h2>
    <p class="next-show-empty-text">Nothing pinned to the running order yet. We’re digging in the crates.</p>
  </div>
)}

<style>
  .next-show-poster {
    width: 100%;
    height: auto;
  }
</style>