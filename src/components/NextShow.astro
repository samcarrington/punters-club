---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import rawResult from "../data/next-show.generated.json";
import { NEXT_SHOW } from "../lib/constants";
import { formatShowTime } from "../lib/local-time";
import type { NextShowResult } from "../lib/next-show";

const result = rawResult as NextShowResult;

const upcoming = result.status === NEXT_SHOW.upcomingStatus ? result.show : undefined;
const cueLabel =
  upcoming?.matchedBy === "guest" ? NEXT_SHOW.guestLabel : NEXT_SHOW.showLabel;

---
<script is:inline>
  const nextShowTime = document.querySelector("[data-next-show-time]");

  if (nextShowTime instanceof HTMLTimeElement) {
    const startsAtUtc = nextShowTime.dateTime;
    const visitorTimeZone = Intl.DateTimeFormat().resolvedOptions().timeZone;

    if (startsAtUtc && visitorTimeZone) {
      const startsAt = new Date(startsAtUtc);
      const formatter = new Intl.DateTimeFormat(navigator.language || "en-GB", {
        weekday: "short",
        day: "numeric",
        month: "short",
        year: "numeric",
        hour: "2-digit",
        minute: "2-digit",
        timeZoneName: "short",
        timeZone: visitorTimeZone,
      });

      nextShowTime.textContent = formatter.format(startsAt);
      nextShowTime.title = `Local time: ${visitorTimeZone}`;
    }
  }
</script>

{result.status === NEXT_SHOW.upcomingStatus ? (
  <article class="next-show-insert">
    <header class="next-show-header">
      <h2 class="next-show-label">{NEXT_SHOW.sectionTitle}</h2>
      <span class="next-show-match-badge">{cueLabel}</span>
    </header>
    <div class="next-show-body">
      {result.show.posterUrl && (
        <Image
          src={result.show.posterUrl}
          alt={NEXT_SHOW.posterAlt}
          height="512"
          width="512"
          class="next-show-poster"
          loading="lazy"
        />
      )}

      <div class="next-show-details">
        <time class="next-show-when" datetime={result.show.startsAtUtc} data-next-show-time>
          {formatShowTime(result.show.startsAtUtc, result.show.timezone)}
        </time>
        <h3 class="next-show-title">{result.show.title}</h3>
        {result.show.description && <p class="next-show-desc">{result.show.description}</p>}
        <a href={result.show.url} class="next-show-link link-external" target="_blank" rel="noreferrer">
          {NEXT_SHOW.ctaLabel}
          <span class="sr-only"> (opens in new tab)</span>
          <Icon height=".8em" name="gridicons:external" />
        </a>
      </div>
    </div>
  </article>
) : (
  <div class="next-show-insert is-empty">
    <h2 class="next-show-label">{NEXT_SHOW.sectionTitle}</h2>
    <p class="next-show-empty-text">{NEXT_SHOW.emptyText}</p>
  </div>
)}

<style>
  .next-show-poster {
    width: 100%;
    height: auto;
  }
</style>
