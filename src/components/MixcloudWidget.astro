---
import { type Show, widgetUrl } from "../lib/mixcloud";

const { show, variant = "mini" } = Astro.props as {
  show: Show;
  variant?: "mini" | "classic";
  placement?: "home" | "show";
};
---

<iframe
  id={`mxc-widget`}
  class:list={["mixcloud-widget", `mixcloud-widget-${variant}`]}
  src={widgetUrl(show.url, variant)}
  title={`Mixcloud player for ${show.title}`}
  loading="lazy"
  allow="autoplay"
></iframe>
