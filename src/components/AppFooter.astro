---
import { Image } from "astro:assets";
import { RADIO_WATERS, SITE } from "../lib/constants";
---

<section id="about" class="pre-footer band" aria-labelledby="about-title">
  <h2 id="about-title">Why we're here</h2>
  <div class="about-copy">
  <p>We are punters first: listeners, dancers, with a lifetime around sound systems. No DJ mystique, no industry gloss, just years of love for records and the thrill of sharing them.</p>
  <p>The Punters' Club flips the script: amateurs entertaining the professionals for an hour each, with joy, taste, and a lot of fun.</p>
  </div>
</section>
<footer class="site-footer band footer-statement">
  <p>{SITE.name} · on {RADIO_WATERS.name}</p>
  <a class="radio-waters-logo-link" href={RADIO_WATERS.url} target="_blank" rel="noreferrer" aria-label={`${RADIO_WATERS.name} website`}>
    <Image src="/assets/radio-waters-white-transparent.png" alt={RADIO_WATERS.name} width={850} height={499} loading="lazy" decoding="async" />
    <span class="sr-only">{RADIO_WATERS.name} website (opens in new tab)</span>
  </a>
</footer>
