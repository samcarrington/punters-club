---
import NextShow from "../components/NextShow.astro";
---
<section class="hero marquee-hero" aria-labelledby="hero-title">
  <div class="hero-content">
    <p class="hero-kicker" style="display: none">
      Disco and House to modern electronic on Radio Waters
    </p>
    <h1 id="hero-title">Seasoned amateurs, serious records.</h1>
    <p class="hero-copy">
      A husband-and-wife duo with a dancer's ear, a punter's instinct, and a
      love for music. Every show is a warm, late-night blend of disco, house,
      and left-field electronic.
    </p>
    <div class="hero-actions">
      <a class="btn btn-primary" href="#latest-show">Play latest show</a>
      <a class="btn btn-secondary" href="/shows">Browse archive</a>
    </div>
  </div>
  <aside class="hero-next-show-rail" aria-label="Next show">
    <NextShow />
  </aside>
</section>
