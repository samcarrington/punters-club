---
import "../styles/global.css";
import "../styles/tokens.css";

import HomeHero from "../components/HomeHero.astro";
import LatestShow from "../components/LatestShow.astro";
import PlaylistGrid from "../components/PlaylistGrid.astro";
import ShowArchive from "../components/ShowArchive.astro";
import playlists from "../data/playlists.generated.json";
import shows from "../data/shows.generated.json";
import PuntersLayout from "../layouts/PuntersLayout.astro";
import {
  buildCollectionPageStructuredData,
  serializeJsonLd,
} from "../lib/structured-data";

const latestShow = shows.at(-1);
const archiveShows = shows.slice(0, -1).reverse();
const structuredDataShows = latestShow
  ? [latestShow, ...archiveShows]
  : archiveShows;
const structuredData = buildCollectionPageStructuredData({
  shows: structuredDataShows,
  playlists,
  pageUrl: new URL("/", Astro.site || "https://punters.club").toString(),
});
---

<PuntersLayout title="The Punters' Club | Radio Waters">
  <script type="application/ld+json" set:html={serializeJsonLd(structuredData)} />
  <HomeHero />
  <section id="latest-show" class="band band-latest" aria-labelledby="latest-title">
    <header class="band-header">
      <h2 id="latest-title">Latest show</h2>
      <p class="band-note">New episodes are posted after broadcast.</p>
    </header>
    <div class="band-content">
      {latestShow && <LatestShow show={latestShow} />}
    </div>
  </section>
  <section id="archive" class="panel" aria-labelledby="archive-title">
    <h2 id="archive-title">Archive shows</h2>
    <ShowArchive shows={archiveShows} />
  </section>
  <section id="playlists" class="panel panel-flush" aria-labelledby="playlist-title">
    <h2 id="playlist-title">Playlists</h2>
    <p class="panel-note">Not all our choices make it to the show, and sometimes we just want to share what we're listening to.</p>
    <PlaylistGrid playlists={playlists} />
  </section>
</PuntersLayout>
