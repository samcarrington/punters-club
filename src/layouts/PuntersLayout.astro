---
import BaseHead from '../components/BaseHead.astro';
import AppHeader from '../components/AppHeader.astro';
import AppFooter from '../components/AppFooter.astro';
const { title } = Astro.props;
---
<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="The Punters' Club: disco and modern electronic selections from a husband-and-wife DJ duo on Radio Waters." />
  </head>
  <body>
    <AppHeader />
    <main id="top">
      <slot />
    </main>
    <AppFooter />
  </body>
</html>